# RailSmart Backend Environment (EXAMPLE)
# Copy to `backend/.env` and fill your own values.

PORT=5000
NODE_ENV=development

# Frontend origin (comma-separated origins allowed)
FRONTEND_URL=http://localhost:5173

# JWT
JWT_SECRET=replace_with_a_long_random_secret

# Postgres (example)
DATABASE_URL=postgres://postgres:password@localhost:5432/railsmart
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=railsmart
DB_PORT=5432
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=2000

# Admin
ADMIN_EMAILS=your_email@gmail.com

# Logging
LOG_LEVEL=debug

# In-memory cache (analytics)
CACHE_TTL_SECONDS=60
CACHE_CHECK_PERIOD_SECONDS=120

# Email (optional)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Razorpay (TEST MODE)
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_key_secret_here

# Force real gateway only (no simulated payment fallback)
ALLOW_SIMULATED_PAYMENTS=false
